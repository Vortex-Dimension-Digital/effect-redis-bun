{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		":dependencyDashboard",
		":semanticCommits",
		":preserveSemverRanges"
	],
	"schedule": ["before 9am on Monday"],
	"timezone": "Europe/Madrid",
	"labels": ["dependencies", "automated"],
	"assignees": ["@arch-fan"],
	"reviewers": ["@arch-fan"],
	"prConcurrentLimit": 5,
	"prHourlyLimit": 2,
	"commitMessagePrefix": "chore(deps):",
	"commitMessageAction": "update",
	"commitMessageExtra": "to {{newVersion}}",
	"commitMessageTopic": "{{depName}}",
	"semanticCommits": "enabled",
	"packageRules": [
		{
			"description": "Group Effect ecosystem updates",
			"groupName": "Effect ecosystem",
			"matchPackagePatterns": ["^effect$", "^@effect/"],
			"automerge": false,
			"schedule": ["before 9am on Monday"]
		},
		{
			"description": "Automerge dev dependency patches",
			"matchDepTypes": ["devDependencies"],
			"matchUpdateTypes": ["patch"],
			"automerge": true,
			"automergeType": "pr",
			"automergeStrategy": "squash"
		},
		{
			"description": "Automerge minor updates for dev tools",
			"matchDepTypes": ["devDependencies"],
			"matchUpdateTypes": ["minor"],
			"matchPackagePatterns": ["^@biomejs/", "typescript"],
			"automerge": true,
			"automergeType": "pr"
		},
		{
			"description": "Group GitHub Actions",
			"groupName": "GitHub Actions",
			"matchManagers": ["github-actions"],
			"automerge": true,
			"schedule": ["before 9am on the first day of the month"]
		},
		{
			"description": "Separate majors for manual review",
			"matchUpdateTypes": ["major"],
			"dependencyDashboardApproval": true,
			"automerge": false
		},
		{
			"description": "Pin Bun runtime - review carefully",
			"matchPackageNames": ["bun-types"],
			"matchUpdateTypes": ["major"],
			"dependencyDashboardApproval": true,
			"labels": ["dependencies", "breaking-change", "needs-review"]
		}
	],
	"vulnerabilityAlerts": {
		"labels": ["security", "priority-high"],
		"assignees": ["@arch-fan"],
		"automerge": false
	},
	"lockFileMaintenance": {
		"enabled": true,
		"schedule": ["before 9am on the first day of the month"],
		"automerge": true
	},
	"postUpdateOptions": ["bunInstall"],
	"ignoreDeps": [],
	"ignorePresets": [],
	"rangeStrategy": "bump"
}
